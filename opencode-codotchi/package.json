{
  "name": "opencode-codotchi",
  "version": "2.10.2",
  "description": "A virtual Tamagotchi-style pet that lives inside OpenCode — globally installable via npm",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-codotchi": "bin/install.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle-plugin.js",
    "prepublishOnly": "npm run build",
    "test:node": "tsc -p tsconfig.test.json && node --test out-test/tests/unit/asciiArt.test.js out-test/tests/unit/statePath.test.js",
    "test:plugin": "node scripts/bundle-plugin.js && bun test tests/unit/pluginContract.test.ts",
    "test": "npm run test:node && npm run test:plugin"
  },
  "keywords": ["opencode", "plugin", "tamagotchi", "virtual-pet", "codotchi"],
  "author": "dylscoop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dylscoop/codotchi.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.27"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist/",
    "commands/",
    "bin/",
    "config/"
  ]
}
